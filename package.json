{
  "name": "displave",
  "version": "0.1.0",
  "description": "Workspace snapshot app for macOS",
  "main": "src/main/index.js",
  "author": "ShinjiroMoriya",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jiromo.displave",
    "productName": "Displave",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "files": [
      "src/**/*",
      "assets/**/*"
    ]
  }
}
